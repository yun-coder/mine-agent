# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=qwen3:8b

# Qdrant
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_COLLECTION=enterprise_kb

# Paths
DOCS_DIR=F:/data/docs
PROJECT_ROOT=F:/projects

# Agent settings
MAX_ITERATIONS=5
TOP_K_RAG=10
TOP_K_CODE=20
STREAM_CHUNK_SIZE=4

# Embedding
EMBED_MODEL=bge-m3
EMBED_DIM=1024

# Langfuse (optional observability)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://127.0.0.1:3001

# PostgreSQL checkpointer (optional persistence)
PG_DSN=
