# ============================================================
# TDAI Memory — 四层记忆系统配置
# ============================================================
# Gateway 地址（Docker 内使用服务名，本地开发使用 127.0.0.1）
TDAI_GATEWAY_URL=http://127.0.0.1:8420
# 启用记忆（设 false 可禁用，不影响现有流程）
TDAI_ENABLED=true
# 记忆召回数量
TDAI_RECALL_TOP_K=5

# Embedding 模型配置
EMBED_MODEL=bge-m3
EMBED_DIM=1024
